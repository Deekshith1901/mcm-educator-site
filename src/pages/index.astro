---
import Navbar from '../components/Navbar.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout title="Mamidi Chandra Mohan | Educator">
	<Navbar />
	<!-- Hero Section -->
	<header id="home" class="min-h-screen flex flex-col justify-center items-center text-center px-4 pt-24 bg-gradient-to-b from-slate-900 via-slate-800 to-slate-900">
		<div class="mb-8 relative">
			<div class="w-48 h-48 rounded-full border-4 border-amber-400 p-1 shadow-2xl overflow-hidden mx-auto">
				<img src="/dad-photo.jpeg" alt="Mamidi Chandra Mohan" class="w-full h-full object-cover rounded-full" />
			</div>
		</div>
		<!-- Line 14-16: Name and Honorary Title -->
<h1 class="text-5xl md:text-7xl font-bold text-white mb-2">MAMIDI CHANDRA MOHAN</h1>

<div class="flex flex-col items-center gap-3 mb-8">
    <!-- The Professional Title -->
    <p class="text-xl md:text-2xl text-amber-400 font-light tracking-widest uppercase">Senior Language Educator & Mentor</p>
    
    <!-- The Honorary Distinction (Chukkallo Chandrudu) -->
    <div class="inline-flex items-center px-4 py-1 rounded-full border border-amber-400/30 bg-amber-400/10 backdrop-blur-sm transition-all duration-200 hover:scale-105">
        <span class="text-amber-400 mr-2 text-lg">✦</span>
        <span class="text-slate-200 font-medium italic tracking-wide">"Chukkallo Chandrudu"</span>
        <span class="text-amber-400 ml-2 text-lg">✦</span>
    </div>
    <p class="text-xs text-slate-500 uppercase tracking-tighter">— Honorary Title conferred by Colleagues & Peers —</p>
</div>
		<p class="max-w-2xl text-slate-400 text-lg leading-relaxed">
			A distinguished linguist and educator with over 30 years of experience shaping young minds through the art of storytelling and the beauty of Hindi and Telugu literature.
		</p>
	</header>

	<!-- About / Philosophy -->
	<section id="about" class="py-20 px-6 max-w-5xl mx-auto scroll-mt-28">
		<div class="grid md:grid-cols-2 gap-12 items-center">
			<div>
				<h2 class="text-3xl font-bold text-amber-400 mb-6">Teaching Philosophy</h2>
				<p class="text-slate-300 text-lg leading-relaxed mb-4">
					"Education is not the filling of a pail, but the lighting of a fire." 
				</p>
				<p class="text-slate-400">
					With a career spanning three decades, I believe that learning a language should be an experience, not a chore. By weaving humor and stories into my lessons, I create a vibrant classroom atmosphere where students feel safe to explore, laugh, and grow.
				</p>
			</div>
			<div class="bg-slate-800 p-8 rounded-2xl border border-slate-700 shadow-xl transition-all duration-200 hover:scale-105">
				<h3 class="text-xl font-bold text-white mb-4 italic">"The Fun Factor"</h3>
				<p class="text-slate-400">
					Whether it's a clever joke or a moral tale, my goal is to ensure every student from Grade 4 to 7 leaves the classroom with a smile and a new understanding of our cultural heritage.
				</p>
			</div>
		</div>
	</section>

	<!-- Experience Timeline -->
	<section id="experience" class="py-20 bg-slate-800/50 scroll-mt-28">
		<div class="max-w-4xl mx-auto px-6">
			<h2 class="text-4xl font-bold text-center text-white mb-16">30+ Years of Excellence</h2>
			<div class="space-y-8 border-l-2 border-amber-400/30 ml-4 pl-8">
				<div class="relative">
					<div class="absolute -left-[41px] top-1 w-4 h-4 rounded-full bg-amber-400 shadow-[0_0_10px_#fbbf24]"></div>
					<h3 class="text-xl font-bold text-amber-400">2003 - Present</h3>
					<p class="text-white font-semibold text-lg">D.A.V. B.D.L. Public School (CBSE)</p>
					<p class="text-slate-400 italic">Senior Language Educator (Hindi & Telugu)</p>
				</div>
				<div class="relative">
					<div class="absolute -left-[41px] top-1 w-4 h-4 rounded-full bg-slate-600"></div>
					<h3 class="text-xl font-bold text-slate-400">2001 - 2002</h3>
					<p class="text-white font-semibold">Vignan School</p>
					<p class="text-slate-400 italic">State Board Education</p>
				</div>
				<div class="relative">
					<div class="absolute -left-[41px] top-1 w-4 h-4 rounded-full bg-slate-600"></div>
					<h3 class="text-xl font-bold text-slate-400">1999 - 2001</h3>
					<p class="text-white font-semibold">Swamynarayan Gurukul (CBSE)</p>
					<p class="text-slate-400 italic">Language Faculty</p>
				</div>
				<div class="relative">
					<div class="absolute -left-[41px] top-1 w-4 h-4 rounded-full bg-slate-600"></div>
					<h3 class="text-xl font-bold text-slate-400">1996 - 1999</h3>
					<p class="text-white font-semibold">Belle Vue School</p>
					<p class="text-slate-400 italic">State Board Education</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Education & Skills -->
	<section id="education" class="py-20 px-6 max-w-6xl mx-auto scroll-mt-28">
		<div class="grid md:grid-cols-3 gap-8">
			<div class="md:col-span-2">
				<h2 class="text-3xl font-bold text-white mb-8 border-b border-amber-400 pb-2 inline-block">Academic Credentials</h2>
				<div class="grid sm:grid-cols-2 gap-6">
					<div class="bg-slate-800 p-6 rounded-lg">
						<p class="text-amber-400 font-bold uppercase text-xs mb-2 tracking-widest">Master of Arts</p>
						<p class="text-white">Hindi & Telugu</p>
						<p class="text-slate-500 text-sm">B.R. Ambedkar Open University / Hindu Sahitya Sammelan</p>
					</div>
					<div class="bg-slate-800 p-6 rounded-lg">
						<p class="text-amber-400 font-bold uppercase text-xs mb-2 tracking-widest">Education Degree</p>
						<p class="text-white">B.Ed. (Hindi)</p>
						<p class="text-slate-500 text-sm">Dakshin Bharat Hindi Prachar Sabha, Madras</p>
					</div>
					<div class="bg-slate-800 p-6 rounded-lg">
						<p class="text-amber-400 font-bold uppercase text-xs mb-2 tracking-widest">Bachelor of Arts</p>
						<p class="text-white">B.A. Graduate</p>
						<p class="text-slate-500 text-sm">Hindu Prachar Sabha, Hyderabad</p>
					</div>
					<div class="bg-slate-800 p-6 rounded-lg">
						<p class="text-amber-400 font-bold uppercase text-xs mb-2 tracking-widest">Certifications</p>
						<p class="text-white">Workshop Participation</p>
						<p class="text-slate-500 text-sm"> Gowtham Model School & DAV College Managing Committee - New Delhi</p>
					</div>
				</div>
			</div>
			<div class="bg-amber-400/5 p-8 rounded-2xl border border-amber-400/20 transition-all duration-200 hover:scale-105">
				<h2 class="text-2xl font-bold text-amber-400 mb-6">Expertise</h2>
				<ul class="space-y-4 text-slate-300">
					<li class="flex items-center"><span class="text-amber-400 mr-2">✓</span> Hindi & Telugu Pedagogy</li>
					<li class="flex items-center"><span class="text-amber-400 mr-2">✓</span> Mentorship & Counseling</li>
					<li class="flex items-center"><span class="text-amber-400 mr-2">✓</span> Classroom Management</li>
					<li class="flex items-center"><span class="text-amber-400 mr-2">✓</span> Digital Tools: MS Office, G-Classroom</li>
				</ul>
			</div>
		</div>
	</section>

	<!-- Testimonials -->
	<section id="stories" class="py-20 bg-slate-900 scroll-mt-28">
		<div class="max-w-4xl mx-auto px-6 text-center">
			<h2 class="text-3xl font-bold text-white mb-12">Student Stories</h2>
			<div class="grid gap-8 italic text-slate-400">
				<blockquote class="text-xl">
					"Lessons were never just about grammar; they were about life. His humor and stories made every class memorable."
				</blockquote>
				<blockquote class="text-xl">
					"The most approachable teacher in the staffroom. His ability to connect with Grade 4 students and Grade 7 students with equal charm is why everyone calls him their favorite."
				</blockquote>
				<blockquote class="text-xl">
					"His command over Telugu and Hindi literature is unmatched. But more than the subject, he taught us how to be confident. A true 'Chukkallo Chandrudu' who lights up the classroom."
				</blockquote>
				<blockquote class="text-xl">
					"Class was never a chore with Chandra Mohan Sir. He has this incredible gift of turning complex Hindi poetry into hilarious, relatable stories. I still remember the jokes he told in 2005!"
				</blockquote>
				<p class="text-amber-400 not-italic font-bold">— A Student Legacy</p>
			</div>
		</div>
	</section>

	<!-- Contact Form (Netlify Ready) -->
	<section id="contact" class="py-20 px-6 bg-slate-800">
		<div class="max-w-3xl mx-auto">
			<h2 class="text-4xl font-bold text-center text-white mb-4">Get in Touch</h2>
			<p class="text-center text-slate-400 mb-12">Available for academic consulting, workshops, or mentorship inquiries.</p>
			
			<form id="contact-form" name="contact" method="POST" data-netlify="true" class="space-y-6">
				<input type="hidden" name="form-name" value="contact" />
				<div class="grid md:grid-cols-2 gap-6">
					<input type="text" name="name" placeholder="Your Name" required class="w-full bg-slate-900 border border-slate-700 p-4 rounded-lg focus:outline-none focus:border-amber-400 text-white" />
					<input type="email" name="email" placeholder="Your Email" required class="w-full bg-slate-900 border border-slate-700 p-4 rounded-lg focus:outline-none focus:border-amber-400 text-white" />
				</div>
				<textarea name="message" rows="5" placeholder="Your Message" required class="w-full bg-slate-900 border border-slate-700 p-4 rounded-lg focus:outline-none focus:border-amber-400 text-white"></textarea>
				<button type="submit" class="w-full bg-amber-400 text-slate-900 font-bold py-4 rounded-lg hover:bg-white transition-all transform hover:scale-105">Send Message</button>
				<div id="form-status" class="hidden mt-4 rounded-lg border p-4 text-center text-sm"></div>
			</form>
			
			<div class="mt-12 text-center text-slate-400 border-t border-slate-700 pt-8">
				<p>Email: mamidichandramohan@gmail.com</p>
				<p>Phone: +91 9440382018</p>
			</div>
		</div>
	</section>

	<footer class="py-10 text-center text-slate-600 text-sm">
		<p>&copy; 2026 MAMIDI CHANDRA MOHAN. Built with Love.</p>
	</footer>

	<script is:inline>
		const form = document.getElementById('contact-form');
		const status = document.getElementById('form-status');
		if (form && status) {
			form.addEventListener('submit', async (event) => {
				event.preventDefault();
				const formData = new FormData(form);
				try {
					const response = await fetch('/', {
						method: 'POST',
						body: formData,
					});
					if (response.ok) {
						status.textContent = 'Message sent successfully.';
						status.className = 'mt-4 rounded-lg border border-emerald-400 bg-emerald-500/10 p-4 text-center text-sm text-emerald-200';
						form.reset();
						alert('Message sent successfully.');
					} else {
						throw new Error('Network response not ok');
					}
				} catch (error) {
					status.textContent = 'Sorry, message not sent. Please try again.';
					status.className = 'mt-4 rounded-lg border border-red-400 bg-red-500/10 p-4 text-center text-sm text-red-200';
					console.error(error);
				}
			});
		}
	</script>
</Layout>