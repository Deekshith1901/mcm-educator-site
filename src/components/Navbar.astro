---
---
<nav class="fixed top-0 w-full z-50 bg-slate-900/80 backdrop-blur-md border-b border-white/10">
  <div class="max-w-6xl mx-auto px-6 h-20 flex justify-between items-center">
    <!-- Logo / Initials -->
    <a href="#home" class="text-2xl font-bold text-amber-400 tracking-tighter">
      MCM<span class="text-white"></span>
    </a>

    <!-- Navigation Links -->
    <div class="hidden md:flex items-center gap-4 text-sm font-medium uppercase tracking-widest">
      <a href="#home" class="px-4 py-2 bg-amber-400 text-slate-900 rounded-full hover:bg-white transition-all transform hover:scale-105">Home</a>
      <a href="#about" class="px-4 py-2 bg-amber-400 text-slate-900 rounded-full hover:bg-white transition-all transform hover:scale-105">Philosophy</a>
      <a href="#experience" class="px-4 py-2 bg-amber-400 text-slate-900 rounded-full hover:bg-white transition-all transform hover:scale-105">Experience</a>
      <a href="#education" class="px-4 py-2 bg-amber-400 text-slate-900 rounded-full hover:bg-white transition-all transform hover:scale-105">Education</a>
      <a href="#stories" class="px-4 py-2 bg-amber-400 text-slate-900 rounded-full hover:bg-white transition-all transform hover:scale-105">Stories</a>
      <a href="#contact" class="px-5 py-2 bg-amber-400 text-slate-900 rounded-full hover:bg-white transition-all transform hover:scale-105">Contact</a>
    </div>

    <!-- Simple Mobile Menu Icon (Visible on small screens) -->
    <button id="nav-toggle" type="button" class="md:hidden text-amber-400" aria-label="Toggle navigation menu">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
    </button>
  </div>

  <div id="mobile-menu" class="hidden md:hidden bg-slate-900/95 border-t border-white/10">
    <div class="flex flex-col gap-3 px-6 py-4 text-sm font-medium uppercase tracking-widest">
      <a href="#home" class="px-4 py-2 bg-amber-400 text-slate-900 rounded-full hover:bg-white transition-all transform hover:scale-105">Home</a>
      <a href="#about" class="px-4 py-2 bg-amber-400 text-slate-900 rounded-full hover:bg-white transition-all transform hover:scale-105">Philosophy</a>
      <a href="#experience" class="px-4 py-2 bg-amber-400 text-slate-900 rounded-full hover:bg-white transition-all transform hover:scale-105">Experience</a>
      <a href="#education" class="px-4 py-2 bg-amber-400 text-slate-900 rounded-full hover:bg-white transition-all transform hover:scale-105">Education</a>
      <a href="#stories" class="px-4 py-2 bg-amber-400 text-slate-900 rounded-full hover:bg-white transition-all transform hover:scale-105">Stories</a>
      <a href="#contact" class="px-5 py-2 bg-amber-400 text-slate-900 rounded-full hover:bg-white transition-all transform hover:scale-105">Contact</a>
    </div>
  </div>

  <script is:inline>
    const navToggle = document.getElementById('nav-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    if (navToggle && mobileMenu) {
      navToggle.addEventListener('click', () => {
        mobileMenu.classList.toggle('hidden');
      });
    }
  </script>
</nav>
